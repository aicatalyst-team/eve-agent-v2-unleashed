# Eve Agent V2 Unleashed — Example Configuration
# Copy this file to `.env` and fill in values you need.
# Most users do NOT need to edit anything here — keys can also be entered
# in the UI (Settings → API Keys) on first run.

# === Local Ollama (defaults work for `ollama serve` on this machine) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Default model on launch ===
# Pick the public Ollama tag you want as your default. Examples:
#   jeffgreen311/eve-qwen3.5-4b-S0LF0RG3:latest   (Soul, conversational)
#   eve-unleashed                                  (local 8B liberated alias)
OLLAMA_MODEL=jeffgreen311/eve-qwen3.5-4b-S0LF0RG3:latest

# === Cloud models (OPTIONAL) ===
# Only needed if you want to use qwen3-coder-next:cloud or qwen3.5:397b-cloud.
# Get a key at: https://ollama.com/settings/keys
# You can also paste this in the UI: Settings → API Keys
OLLAMA_API_KEY=

# === Web search (OPTIONAL) ===
# Only needed if you want Eve to do live web search.
# Get a free dev key at: https://app.tavily.com
TAVILY_API_KEY=

# === Workspace (OPTIONAL) ===
# Where Eve reads/writes files. Defaults to the folder this app was launched from.
# EVE_WORKSPACE=

# === Custom system prompt (OPTIONAL) ===
# Path to a .md or .txt file with custom instructions prepended to Eve's
# system prompt. Useful for defining custom personas or workflows.
# EVE_SYSTEM_PROMPT_PATH=/path/to/my_persona.md

# === Provider routing (do not change unless you know what you are doing) ===
EVE_DEFAULT_PROVIDER=ollama
EVE_DEFAULT_MODEL=jeffgreen311/eve-qwen3.5-4b-S0LF0RG3:latest
